{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WithAllOf",
  "description": "Composition: a Cfg class mixes in an Identifiable base via allOf.",
  "definitions": {
    "Identifiable": {
      "type": "object",
      "description": "Generic id/name mixin.",
      "properties": {
        "id":   { "type": "integer", "default": 0 },
        "name": { "type": "string",  "default": "" }
      },
      "required": ["id"]
    },
    "Cfg": {
      "type": "object",
      "allOf": [{ "$ref": "#/definitions/Identifiable" }],
      "properties": {
        "awuser": { "type": "integer", "minimum": 0, "maximum": 15 }
      },
      "required": ["awuser"]
    }
  }
}
