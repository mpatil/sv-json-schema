{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WithStrict",
  "description": "Exercises additionalProperties: false on one class and the default loose behavior on another.",
  "definitions": {
    "Strict": {
      "type": "object",
      "properties": {
        "a": { "type": "integer", "default": 0 },
        "b": { "type": "string",  "default": "hello" }
      },
      "required": ["a"],
      "additionalProperties": false
    },
    "Loose": {
      "type": "object",
      "properties": {
        "x": { "type": "integer", "default": 0 }
      }
    }
  }
}
