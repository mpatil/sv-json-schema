{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WithValidation",
  "description": "Exercises const + minLength/maxLength runtime checks.",
  "definitions": {
    "Cfg": {
      "type": "object",
      "description": "Configuration with validation constraints.",
      "properties": {
        "name":    {
          "description": "Display name (3 to 8 chars).",
          "type": "string", "minLength": 3, "maxLength": 8
        },
        "tag":     { "type": "string",  "const": "v1" },
        "version": { "type": "integer", "const": 1 }
      }
    }
  }
}
